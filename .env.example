ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-6
NEO4J_URI=neo4j+s://your-neo4j-uri
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password
AIRTABLE_API_KEY=your_airtable_api_key_here
AIRTABLE_BASE_ID=your_airtable_base_id

# --- AEGIS public-demo protection (api_bridge.py) ---
# Set DEMO_PASSWORD to gate the whole site + API behind HTTP Basic auth.
# Leave empty for ungated local dev.
DEMO_USER=demo
DEMO_PASSWORD=
RATE_LIMIT_PER_HOUR=60

# --- Local split-dev only (Vite :5173 + bridge :8000) ---
# Set in the frontend so the UI calls the separate backend:
# VITE_API_BASE=http://localhost:8000
